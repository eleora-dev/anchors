{
  "manifest_version": 3,
  "name": "Eleòra Anchors",
  "version": "1.0",
  "description": "__MSG_description__",
  "default_locale": "en",
  "permissions": ["bookmarks", "favicon", "tabs", "browsingData", "clipboardWrite"],
  "author": "Gerardo Perilli",
  "action": {
    "default_popup": "anchors.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
